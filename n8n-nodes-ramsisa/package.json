{
  "name": "n8n-nodes-ramsisa",
  "version": "0.1.4",
  "description": "n8n community node for the Ramsisa field visit scheduling API.",
  "keywords": [
    "n8n-community-node-package",
    "ramsisa",
    "scheduling",
    "field-visits",
    "route-optimization",
    "territory-planning",
    "field-service",
    "sales-routing"
  ],
  "license": "MIT",
  "homepage": "https://ramsisa.com",
  "author": {
    "name": "Ramsisa",
    "email": "framawy@ramsisa.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ramsisa/automation.git",
    "directory": "n8n-nodes-ramsisa"
  },
  "bugs": {
    "url": "https://github.com/Ramsisa/automation/issues"
  },
  "engines": {
    "node": ">=22.16"
  },
  "main": "index.js",
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/RamsisaApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Ramsisa/Ramsisa.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.29.0",
    "prettier": "3.8.3",
    "release-it": "20.0.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
