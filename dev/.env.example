# Local dev environment for testing the Ramsisa automation workflows.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# n8n encryption key. Generate with:
#   openssl rand -hex 32
# Set ONCE per local install. Changing it invalidates all stored credentials.
N8N_ENCRYPTION_KEY=

# Hostname the n8n UI is reachable on (browser-facing).
N8N_HOST=localhost

# Public base URL n8n advertises for webhooks. Keep as localhost for
# in-machine testing. For Ramsisa webhooks fired from schedule.ramsisa.com,
# point this at a tunnel URL (cloudflared, ngrok) — see dev/README.md.
WEBHOOK_URL=http://localhost:5679/

# Timezone for the n8n scheduler.
TZ=
